generator client {
  provider        = "prisma-client-js"
 
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  hashedPassword   String
  displayName      String
  leaderboardOptIn Boolean  @default(false)
  createdAt        DateTime @default(now())

  brokerConnections  BrokerConnection[]
  watchlistItems     WatchlistItem[]
  alerts             Alert[]
  portfolioSnapshots PortfolioSnapshot[]
  alertPreferences   AlertPreference[]

  friendCode   FriendCode?
  friendships  Friendship[] @relation("UserFriends")
  friendOf     Friendship[] @relation("FriendOf")

  userStats    UserStats?
  achievements UserAchievement[]

  xpEvents             XpEvent[]
  weeklyChallengeDone  UserWeeklyChallenge[]

  polymarketAlerts   PolymarketAlert[]

  signalScores SignalScore[]

  recommendations StockRecommendation[]
  

}

model BrokerConnection {
  id             String    @id @default(uuid())
  userId         String
  provider       String
  encryptedToken String
  accountId      String
  lastSyncedAt   DateTime?

  user     User      @relation(fields: [userId], references: [id])
  holdings Holding[]
}

model Holding {
  id                 String   @id @default(uuid())
  brokerConnectionId String
  ticker             String
  quantity           Decimal
  avgCostBasis       Decimal
  updatedAt          DateTime @updatedAt

  brokerConnection BrokerConnection @relation(fields: [brokerConnectionId], references: [id])
}

model WatchlistItem {
  id      String   @id @default(uuid())
  userId  String
  ticker  String
  addedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Alert {
  id                  String   @id @default(uuid())
  userId              String
  ticker              String
  alertType           String
  plainEnglishSummary String
  riskNote            String
  isRead              Boolean  @default(false)
  triggeredAt         DateTime @default(now())

  // News + Reddit context (added to match alertEvaluator.js)
  newsUrl       String?
  newsHeadline  String?
  redditUrl     String?
  redditTitle   String?

  user User @relation(fields: [userId], references: [id])
}

model AlertPreference {
  id        String   @id @default(uuid())
  userId    String
  alertType String   // matches the alert type keys below
  enabled   Boolean  @default(true)
  threshold Decimal? // optional — used for % thresholds like price move, portfolio change
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, alertType]) // one row per user per alert type
}

// AlertPreference alertType values:
// --- Real-time ---
// "large_holding_move"       — individual stock moves X% and is >= min portfolio weight
// "portfolio_value_change"   — total portfolio moves X% or $X in a day
// "drawdown"                 — portfolio drops X% from 30-day high
// "watchlist_price_target"   — watchlist stock crosses user-set price target
// "major_news"               — major news on held or watchlisted stock
// "earnings"                 — earnings reminder + post-earnings alert
// "volume_spike"             — unusual volume on held or watchlisted stock
//
// --- Digest (batched) ---
// "concentration_risk"       — one holding exceeds X% of portfolio (weekly reminder)
// "cost_basis_deviation"     — holding moves X% from cost basis
// "dividend_corporate"       — ex-dividend dates, splits, mergers
// "reddit_alignment"         — Reddit + price + news multi-signal
// "watchlist_move"           — watchlist stock moves X% with no price target set
// "watchlist_news"           — news on watchlist stock (digest unless high-priority)
//
// --- Leaderboard ---
// "rank_passed"              — someone passes your rank
// "top_3_entered"            — you enter top 3 or top 10
// "streak_milestone"         — performance streak or milestone
//
// --- Digests ---
// "daily_digest"             — daily after-market email
// "weekly_digest"            — weekly Saturday morning email
// "sms_realtime"             — SMS for real-time alerts

model PortfolioSnapshot {
  id             String   @id @default(uuid())
  userId         String
  totalValue     Decimal
  dailyPctChange Decimal
  snapshotAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model FriendCode {
  id        String   @id @default(cuid())
  userId    String   @unique
  code      String   @unique
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Friendship {
  id        String   @id @default(cuid())
  userId    String
  friendId  String
  createdAt DateTime @default(now())
  user      User     @relation("UserFriends", fields: [userId], references: [id])
  friend    User     @relation("FriendOf", fields: [friendId], references: [id])

  @@unique([userId, friendId])
}

model UserStats {
  id             String    @id @default(cuid())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  xp             Int       @default(0)
  streak         Int       @default(0)
  bestStreak     Int       @default(0)
  lastActiveDate DateTime?
  freezeAvailable Boolean  @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model UserAchievement {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementKey String
  earnedAt       DateTime @default(now())

  @@unique([userId, achievementKey])
}

model XpEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  delta     Int
  reason    String
  createdAt DateTime @default(now())
}

model WeeklyChallenge {
  id          String   @id @default(cuid())
  weekStart   DateTime
  key         String
  label       String
  description String
  xpReward    Int
  createdAt   DateTime @default(now())

  @@unique([weekStart, key])
}

model UserWeeklyChallenge {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStart         DateTime
  challengeKey      String
  completedAt       DateTime?
  createdAt         DateTime @default(now())

  @@unique([userId, weekStart, challengeKey])
}

model SecurityMetadata {
  id          String   @id @default(uuid())
  ticker      String   @unique
  companyName String   @default("") @map("company_name")
  sector      String   @default("Unknown")
  industry    String   @default("Unknown")
  marketCap   BigInt?  @map("market_cap")
  source      String   @default("polygon")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([sector])
  @@index([updatedAt])
  @@map("security_metadata")
}

model PolymarketEvent {
  id        String   @id
  title     String
  category  String?
  endDate   DateTime?
  syncedAt  DateTime @default(now())

  markets  PolymarketMarket[]
  mappings PolymarketEventMapping[]

  slug      String?

}

model PolymarketMarket {
  id              String   @id
  eventId         String
  question        String?
  currentYesProb  Decimal?
  previousYesProb Decimal?
  lastShiftAt     DateTime?
  updatedAt       DateTime @default(now())

  event   PolymarketEvent  @relation(fields: [eventId], references: [id])
  alerts  PolymarketAlert[]
}

model PolymarketEventMapping {
  id       String   @id @default(uuid())
  eventId  String
  ticker   String
  mappedAt DateTime @default(now())

  event PolymarketEvent @relation(fields: [eventId], references: [id])

  @@unique([eventId, ticker])
}

model PolymarketAlert {
  id             String   @id @default(uuid())
  userId         String
  marketId       String
  ticker         String
  alertType      String
  message        String
  shiftMagnitude Decimal?
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  user   User             @relation(fields: [userId], references: [id])
  market PolymarketMarket @relation(fields: [marketId], references: [id])
}

model SignalScore {
  id             String   @id @default(uuid())
  ticker         String
  userId         String
  priceScore     Decimal?
  volumeScore    Decimal?
  newsScore      Decimal?
  redditScore    Decimal?
  polyScore      Decimal?
  compositeScore Decimal
  label          String
  computedAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([ticker, userId])
}

model StockRecommendation {
  id          String   @id @default(uuid())
  userId      String
  ticker      String
  recType     String
  reasoning   String
  signalScore Decimal?
  label       String?
  isNew       Boolean  @default(true)
  computedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, ticker])
}